{
  "info": {
    "name": "PhoneShop API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"newuser\",\"email\":\"new@example.com\",\"password\":\"pass123\",\"password2\":\"pass123\"}"
            }
          }
        },
        {
          "name": "Login (saves tokens)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j=pm.response.json();pm.collectionVariables.set(\"access_token\",j.access);pm.collectionVariables.set(\"refresh_token\",j.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"testuser\",\"password\":\"test123\"}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refresh\":\"{{refresh_token}}\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Phones",
      "item": [
        {
          "name": "List All Phones",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/phones/"
          }
        },
        {
          "name": "Get Phone Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/phones/1/"
          }
        },
        {
          "name": "Search Phones",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/phones/search/?query=samsung&min_price=200"
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories/"
          }
        },
        {
          "name": "Create Phone (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/phones/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"category\":1,\"name\":\"Test Phone\",\"brand\":\"TestBrand\",\"model\":\"TP-1\",\"price\":299.99,\"description\":\"Test\",\"stock\":10,\"ram\":\"6GB\",\"storage\":\"128GB\",\"battery\":\"4000mAh\",\"camera\":\"48MP\"}"
            }
          }
        },
        {
          "name": "Update Phone (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/phones/1/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"price\":999.99}"
            }
          }
        },
        {
          "name": "Delete Phone (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/phones/99/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cart/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/cart/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\":1,\"quantity\":1}"
            }
          }
        },
        {
          "name": "Update Cart Item Qty",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/cart/1/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"quantity\":3}"
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/cart/1/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/cart/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/checkout/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"shipping_address\":\"123 Main St, Almaty, Kazakhstan\"}"
            }
          }
        }
      ]
    }
  ]
}